<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Camera -->
    <key>NSCameraUsageDescription</key>
    <string>PopBom requires camera access to record videos and capture photos.</string>

    <!-- Microphone -->
    <key>NSMicrophoneUsageDescription</key>
    <string>PopBom requires microphone access to record audio during video recording.</string>

    <!-- Speech Recognition -->
    <key>NSSpeechRecognitionUsageDescription</key>
    <string>PopBom uses speech recognition to enable voice input and audio-based features.</string>

    <!-- Photo Library (read) -->
    <key>NSPhotoLibraryUsageDescription</key>
    <string>PopBom needs access to your photo library to select images and videos.</string>

    <!-- Photo Library (write/save) -->
    <key>NSPhotoLibraryAddUsageDescription</key>
    <string>PopBom needs permission to save generated videos to your gallery.</string>

    <!-- Media / Music (only if audio picking is used) -->
    <key>NSAppleMusicUsageDescription</key>
    <string>PopBom needs access to media files for audio selection.</string>



	<key>ASAuthorizationAppleIDButtonType</key>
	<string>SignIn</string>
	<key>CADisableMinimumFrameDurationOnPhone</key>
	<true/>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleDisplayName</key>
	<string>Popbom</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>popbom</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(FLUTTER_BUILD_NAME)</string>
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleTypeRole</key>
            <string>Editor</string>
            <key>CFBundleURLSchemes</key>
			<array>
              <string>com.googleusercontent.apps.549869929938-lr4kpanos55s215qb2q7gc0g2plseo5r</string>
            </array>
		</dict>
	</array>
	<key>CFBundleVersion</key>
	<string>$(FLUTTER_BUILD_NUMBER)</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>NSAppleMusicUsageDescription</key>
	<string>App needs access to Apple ID for Sign in with Apple</string>
	<key>NSCameraUsageDescription</key>
	<string>This app requires camera access to record videos.</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>This app needs microphone access.</string>
	<key>NSPhotoLibraryAddUsageDescription</key>
	<string>To save generated video to your gallery.</string>
	<key>UIApplicationSupportsIndirectInputEvents</key>
	<true/>
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
	<key>UIMainStoryboardFile</key>
	<string>Main</string>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
</dict>
</plist>
